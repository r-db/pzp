{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pzp.riscent.com/schemas/manifest.schema.json",
  "title": "PZP Site Manifest",
  "description": "Machine-readable metadata for a Prime Zero Protocol site",
  "type": "object",
  "required": ["version", "name", "description", "type", "updated", "endpoints"],
  "properties": {
    "$schema": {
      "type": "string",
      "const": "https://pzp.riscent.com/schemas/manifest.schema.json"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of this site (MAJOR.MINOR.PATCH)"
    },
    "protocolVersion": {
      "type": "string",
      "default": "1.0.0",
      "description": "Version of the Prime Zero Protocol specification"
    },
    "name": {
      "type": "string",
      "maxLength": 100,
      "description": "Human and LLM readable name for this site"
    },
    "description": {
      "type": "string",
      "maxLength": 500,
      "description": "One-line description of what this site offers"
    },
    "type": {
      "type": "string",
      "enum": ["service", "documentation", "data", "api", "knowledge"],
      "description": "Primary purpose of this PZP site"
    },
    "updated": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last content update"
    },
    "tokenBudgets": {
      "type": "object",
      "description": "Estimated token counts for context files",
      "properties": {
        "essential": {
          "type": "integer",
          "minimum": 0,
          "description": "Token count for essential context"
        },
        "full": {
          "type": "integer",
          "minimum": 0,
          "description": "Token count for full context"
        }
      }
    },
    "endpoints": {
      "type": "object",
      "required": ["context", "actions"],
      "description": "Path mappings for site sections",
      "properties": {
        "context": {
          "type": "string",
          "default": "/context/",
          "description": "Path to context files"
        },
        "actions": {
          "type": "string",
          "default": "/actions/",
          "description": "Path to action definitions"
        },
        "data": {
          "type": "string",
          "default": "/data/",
          "description": "Path to data files"
        },
        "meta": {
          "type": "string",
          "default": "/meta/",
          "description": "Path to metadata files"
        }
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["read", "query", "execute", "write", "subscribe"]
      },
      "description": "What operations agents can perform"
    },
    "authentication": {
      "type": "object",
      "properties": {
        "required": {
          "type": "boolean",
          "default": false
        },
        "methods": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["api-key", "bearer", "oauth2", "none"]
          }
        },
        "documentation": {
          "type": "string",
          "description": "Path to authentication documentation"
        }
      }
    },
    "rateLimit": {
      "type": "object",
      "properties": {
        "requests": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of requests allowed"
        },
        "window": {
          "type": "string",
          "pattern": "^\\d+[smh]$",
          "description": "Time window (e.g., '1m', '1h', '60s')"
        }
      }
    },
    "contact": {
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email"
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Keywords for discoverability"
    }
  },
  "additionalProperties": false
}
